# Ignore local environment variables to protect personal data
.env
.env.*

# Ignore Google API credentials
credentials.json
token.json
client_secret.json
*.json

# Tracked JSON schemas are not credentials
!config/schemas/*.schema.json

# Generated skills index is tracked
!.agents/skills.json

# Ignore synced personal Google Docs
personal_docs/

# Ignore local vector databases
.chromadb/
.chroma/

# Python caching and environments
__pycache__/
*.pyc
venv/
.pytest_cache/
.coverage
coverage.out

# Go binaries and builds (root anchored so cmd/installer sources stay addable)
/ai_installer
/ai_installer.exe
/installer
dist/
/gh_*_linux_amd64/

# Python build output and package metadata
/build/
*.egg-info/

# Local telemetry state
.telemetry/

# Auto-generated docs site mirror (built fresh by `make docs` / CI, deployed to
# gh-pages). docs/index.html, docs/app.js, docs/styles.css, docs/favicon.svg,
# and docs/og-image.jpg are hand-authored frontend source with no generation
# step (see tests/test_frontend.py) and stay tracked.
docs/api/
docs/documentation/
docs/.agents/
docs/assets/
docs/AGENTS.md
docs/GEMINI.md
docs/CLAUDE.md
docs/change_log.md
docs/index.md
docs/_layouts/
docs/_config.yml
/docs/.build-tmp/

# One-off scratch output at the repo root (logs, patches, archives from debugging sessions)
/*.log
/*.diff
/*.zip
