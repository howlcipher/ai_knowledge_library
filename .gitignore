# Ignore local environment variables to protect personal data
.env
.env.*

# Ignore Google API credentials
credentials.json
token.json
client_secret.json
*.json

# Tracked JSON schemas are not credentials
!config/schemas/*.schema.json

# Ignore synced personal Google Docs
personal_docs/

# Ignore local vector databases
.chromadb/
.chroma/

# Python caching and environments
__pycache__/
*.pyc
venv/
.pytest_cache/
.coverage
coverage.out

# Go binaries and builds
ai_installer
installer
dist/

# Auto-generated docs
docs/api/
