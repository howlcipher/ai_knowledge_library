# Personal Environment Variables Template
# Copy this file to `.env` and fill in your personal details.
# The `.env` file is explicitly ignored by Git to keep your data perfectly safe and private.

GOOGLE_DOCS_WORKSPACE_URL=""

# LLM Provider API Keys (set at least one; both may be set)
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# Default LiteLLM model. Uncomment and set to switch providers, e.g.
# "gemini/gemini-1.5-pro" or "anthropic/claude-sonnet-5"
# LLM_MODEL="gemini/gemini-1.5-pro"

# LangSmith Evaluation and Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="ai-knowledge-library"
